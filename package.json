{
  "name": "mdocs",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev:server": "tsx watch src/server/main.ts",
    "dev:web": "vite",
    "build:web": "vite build",
    "build:server": "tsc -p tsconfig.server.json",
    "build": "pnpm build:web && pnpm build:server",
    "start": "node dist/server/main.js",
    "mdocs": "tsx src/server/cli/main.ts",
    "typecheck": "tsc -p tsconfig.server.json --noEmit && tsc -p tsconfig.web.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@meta2d/activity-diagram": "^1.0.1",
    "@meta2d/chart-diagram": "^1.0.21",
    "@meta2d/class-diagram": "^1.0.2",
    "@meta2d/core": "^1.1.19",
    "@meta2d/flow-diagram": "^1.0.2",
    "@meta2d/form-diagram": "^1.0.30",
    "@meta2d/fta-diagram": "^1.0.1",
    "@meta2d/le5le-charts": "^1.0.5",
    "@meta2d/sequence-diagram": "^1.0.1",
    "better-sqlite3": "^11.3.0",
    "canvas2svg": "^1.0.16",
    "express": "^4.21.0",
    "multer": "^2.1.1",
    "react-router-dom": "^7.14.2",
    "vditor": "file:../../ddmc/my-vditor",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/express": "^4.17.21",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.7.0",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.2",
    "jsdom": "^29.0.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2",
    "vite": "^5.4.8",
    "vitest": "2.1.9"
  }
}
