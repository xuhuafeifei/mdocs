{
  "name": "mdocs",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev:server": "tsx watch src/server/main.ts",
    "dev:web": "vite",
    "dev:web:fresh": "vite --force",
    "dev": "pnpm dev:server & pnpm dev:web",
    "build:web": "vite build",
    "build:server": "tsc -p tsconfig.server.json",
    "build": "pnpm build:web && pnpm build:server",
    "start": "node dist/server/main.js",
    "mdocs": "tsx src/server/cli/main.ts",
    "typecheck": "tsc -p tsconfig.server.json --noEmit && tsc -p tsconfig.web.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@lexical/rich-text": "0.42.0",
    "@lobehub/editor": "file:../my-lobe-editor",
    "@lobehub/ui": "^5.0.0",
    "@node-rs/jieba": "^2.0.1",
    "antd": "^6.1.1",
    "antd-style": "^4.1.0",
    "better-sqlite3": "11.10.0",
    "es-toolkit": "^1.46.1",
    "express": "^4.21.0",
    "lexical": "0.42.0",
    "lucide-react": "^0.562.0",
    "motion": "^12.0.0",
    "multer": "^2.1.1",
    "react-router-dom": "^7.14.2",
    "remark": "^15.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/express": "^4.17.21",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.7.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.2",
    "jsdom": "^29.0.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2",
    "vite": "^5.4.8",
    "vitest": "2.1.9"
  }
}
